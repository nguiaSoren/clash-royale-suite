  "scraping_guide": {
    "what_to_extract_per_evo_page": [
      "Ability name (usually bold in first paragraph)",
      "Cycle cost (1 or 2, mentioned in description or infobox)",
      "Stat changes vs base (HP multiplier, damage changes — in stat table or description)",
      "Effect type and values (%, durations in ms, radii)",
      "Balance change history (bottom of page — dates and what changed)"
    ],
    "what_to_extract_per_hero_page": [
      "Ability name and elixir cost",
      "Ability description and all mechanic details",
      "Stat differences from base card",
      "Effect values (radius, duration, damage)",
      "Balance changes"
    ]
  }
