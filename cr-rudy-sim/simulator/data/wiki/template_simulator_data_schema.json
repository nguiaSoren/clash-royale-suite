{
  "_schema_version": "2.0",
  "_description": "Clash Royale Simulator - Data Architecture & Schema",
  "_architecture": {
    "source_1_royaleapi": {
      "description": "RoyaleAPI cr-api-data — base combat, physics, projectiles, buffs, buildings",
      "files": {
        "cards_stats_characters.json": "125 troops/champions, 297 fields — HP, damage, speed, collision, dash, spawn, death, per-level arrays",
        "cards_stats_building.json": "89 buildings, 285 fields — same depth as characters + lifetime, hide mechanics",
        "cards_stats_projectile.json": "92 projectiles — speed, homing, splash radius, gravity, damage",
        "cards_stats_spell.json": "71 spells — radius, duration, pushback, damage, area effects",
        "cards_stats_character_buff.json": "62 buffs — rage multiplier, freeze, poison tick, heal, slow"
      },
      "total_entities": 439
    },
    "source_2_wiki_scrape": {
      "description": "Fandom Wiki scrape — evolution abilities + hero abilities (this file)",
      "url_base": "https://clashroyale.fandom.com/wiki/",
      "scraped_by": "Python scraper targeting individual card wiki pages",
      "files": {
        "evo_hero_abilities.json": "~39 evolution abilities + ~10 hero abilities"
      }
    }
  },

  "_cross_references": {
    "character_to_projectile": "characters[].projectile → projectiles[].name (e.g. 'ArcherArrow')",
    "character_to_buff": "characters[].buff_on_damage → buffs[].name (e.g. 'Rage')",
    "character_to_building": "separate entity pools, no cross-ref needed",
    "evo_to_character": "evolutions[].base_card_key → characters[].key",
    "hero_to_character": "heroes[].base_card_key → characters[].key",
    "evo_buff_to_buff_file": "evolutions[].ability.effects[].buff_reference → buffs[].name"
  },

  "_card_lookup_flow": [
    "1. Player plays 'Knight' → find characters[] where key='knight'",
    "2. Get all 297 combat/physics fields from that entry",
    "3. If card has projectile field → look up projectiles[] by name",
    "4. If evo is active → find evolutions[] where base_card_key='knight'",
    "5.   Apply stat_modifiers on top of base stats",
    "6.   Register ability trigger in combat engine",
    "7. If hero variant → find heroes[] where base_card_key='knight'",
    "8.   Apply stat_modifiers, register ability button with elixir_cost",
    "9. For spells → look up spells[] by name instead of characters[]",
    "10. For buildings → look up buildings[] by name instead of characters[]"
  ],

  "evolutions": {
    "_count": "~39 total",
    "_scrape_url_pattern": "https://clashroyale.fandom.com/wiki/{CardName}/Evolution",

    "schema": {
      "id": "string — unique ID, e.g. 'knight_evo'",
      "base_card_key": "string — links to characters[].key, e.g. 'knight'",
      "base_card_sc_key": "string — links to characters[].sc_key, e.g. 'Knight'",
      "name": "string — display name, e.g. 'Evolved Knight'",
      "cycle_cost": "integer — times base card must be played before evo activates (1 or 2)",
      "elixir": "integer — same as base card",
      "rarity": "string — base card rarity",

      "stat_modifiers": {
        "_description": "Changes relative to base card. null = unchanged.",
        "hitpoints_multiplier": "number|null — e.g. 1.10 = +10% HP",
        "damage_multiplier": "number|null",
        "hit_speed_multiplier": "number|null",
        "speed_override": "integer|null",
        "spawn_count_override": "integer|null",
        "range_override": "integer|null",
        "shield_hitpoints": "integer|null — at tournament level 11"
      },

      "ability": {
        "name": "string — e.g. 'Elbow Reflection'",
        "description": "string — human-readable full description",
        "type": "string — 'passive'|'on_attack'|'on_hit'|'on_kill'|'on_death'|'on_deploy'|'on_damage_taken'|'continuous'|'conditional'",

        "trigger": {
          "condition": "string — 'while_not_attacking'|'on_each_attack'|'on_kill'|'on_deploy'|'when_below_half_hp'|'always_active'",
          "cooldown_ms": "integer|null",
          "max_stacks": "integer|null"
        },

        "effects": [
          {
            "effect_type": "string — 'damage_reduction'|'damage_buff'|'speed_buff'|'hitspeed_buff'|'heal'|'spawn_unit'|'area_pull'|'area_damage'|'projectile_chain'|'projectile_bounce'|'shield_grant'|'freeze'|'stun'|'slow'|'rage'|'clone_on_death'|'respawn'|'custom'",
            "target": "string — 'self'|'enemies_in_radius'|'all_enemies'|'allies_in_radius'|'nearest_enemy'|'attacking_unit'|'ground'|'air'|'ground_and_air'",
            "radius": "integer|null — game units (same scale as RoyaleAPI)",
            "value": "number|null — primary value: reduction %, buff %, heal amount",
            "value_per_level": "array|null",
            "duration_ms": "integer|null — null = permanent/until condition ends",
            "damage": "integer|null — at tournament level 11",
            "damage_per_level": "array|null",
            "spawn_character": "string|null — sc_key of spawned unit",
            "spawn_count": "integer|null",
            "spawn_interval_ms": "integer|null",
            "buff_reference": "string|null — links to character_buff[].name",
            "projectile_behavior": {
              "chain_count": "integer|null",
              "bounce_count": "integer|null",
              "chain_damage_multiplier": "number|null",
              "can_hit_same_target": "boolean|null",
              "hits_crown_towers": "boolean|null"
            },
            "pull_strength": "integer|null",
            "affects_air": "boolean|null",
            "affects_ground": "boolean|null"
          }
        ]
      },

      "release_season": "integer|null",
      "last_balance_date": "string|null"
    },

